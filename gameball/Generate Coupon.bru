meta {
  name: Generate Coupon
  type: http
  seq: 13
}

post {
  url: {{baseUrl}}/coupons/predefined
  body: json
  auth: inherit
}

headers {
  apikey: {{apikey}}
  secretkey: {{secretkey}}
}

body:json {
  {
    "customerId": "{{customerId}}",
    "ruleId": 2138
  }
}

settings {
  encodeUrl: true
}